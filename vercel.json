{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "python BACKEND/app.py",
  "installCommand": "pip install -r requirements.txt",
  "framework": "flask",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
